{
    "schemaVersion": 1,
    "id": "skintotem",
    "version": "1.1.1",
    "name": "SkinTotem",
    "description": "Client-Side Fabric Mod which replaces all totems with player dolls. Rename your totem to player's nickname to use it's skin.",
    "authors": [
        "Darkz",
        "K-TEAM",
        "KlashRaick",
		"LopyMine"
    ],
    "contact": {
        "homepage": "https://github.com/darkz70/SkinTotem",
        "issues": "https://github.com/darkz70/SkinTotem/issues"
    },
    "license": "CC BY-ND 4.0",
    "icon": "icon/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.darkz.skintotem.SkinTotem"
        ],
        "client": [
            "com.darkz.skintotem.client.SkinTotemClient"
        ],
        "modmenu": [
            "com.darkz.skintotem.modmenu.ModMenuIntegration"
        ]
    },
    "depends": {
        "fabricloader": ">=${fabric_loader}",
        "minecraft": ">=${minecraft}",
        "java": ">=${java}",
        "${fabric_api_id}": "*"
    },
    "accessWidener": "${fabric_trick_accesswidener_id}",
    "mixins": [
	    "${fabric_trick_mixin_configs}"
    ]
}
